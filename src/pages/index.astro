---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import HowToOrder from '../components/HowToOrder.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const products = [
  {
    name: 'Macarons surtidos',
    description: 'Caja variada con rellenos de ganache, frutos rojos y limón.',
    image: '/macaronsDos.webp',
    alt: 'Macarons artesanales de colores sobre bandeja de pastelería'
  },
  {
    name: 'Brownies de chocolate',
    description: 'Miga húmeda, cacao intenso y cubierta crocante.',
    image: '/brownie.webp',
    alt: 'Porciones de brownies artesanales sobre plato de cerámica'
  },
  {
    name: 'Alfajores surtidos',
    description: 'Tapas suaves, relleno generoso y borde de coco rallado.',
    image: '/alfajores.webp',
    alt: 'Alfajores artesanales rellenos con dulce de leche'
  },
  {
    name: 'Cookies NY',
    description: 'Manteca, chocolate y frutos secos en una caja para compartir.',
    image: '/cookiesdos.webp',
    alt: 'Caja surtida con galletitas artesanales variadas'
  }
];
---

<BaseLayout
  title="Mandorla Bakery | Pedidos por WhatsApp"
  description="Macarons, brownies, alfajores y especialidades de temporada. Pedidos semanales por WhatsApp."
>
  <main id="contenido">
    <Hero />

    <section class="section section--products" aria-labelledby="productos-title">
      <div class="container">
        <h2 id="productos-title">Especialidades de esta semana</h2>
        <p>Elegí tus favoritos y pedí por WhatsApp en pocos minutos.</p>
        <div class="products-grid">
          {
            products.map((product) => (
              <ProductCard
                name={product.name}
                description={product.description}
                image={product.image}
                alt={product.alt}
              />
            ))
          }
        </div>
      </div>
    </section>

    <HowToOrder />
    <Testimonials />
    <CTA />
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>Mandorla Bakery - Buenos Aires, Argentina</p>
      <div class="footer__links">
        <a href="https://wa.me/5491153154614?text=Hola%2C%20quiero%20pedir%20productos%20de%20pasteler%C3%ADa." target="_blank" rel="noreferrer">
          WhatsApp
        </a>
        <a href="https://www.instagram.com/mandorla.bakes/" target="_blank" rel="noreferrer">
          Instagram
        </a>
        <a href="/Carta%20Mandorla.pdf" target="_blank" rel="noreferrer">
          Carta
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>
