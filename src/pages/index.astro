---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import ProductCard from '../components/ProductCard.astro';
import HowToOrder from '../components/HowToOrder.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const products = [
  {
    name: 'Chocolate intenso',
    description: 'Cacao amargo, centro suave y bordes crocantes.',
    price: '$5.800 / docena',
    image: '/images/product-chocolate.webp',
    alt: 'Galletitas de chocolate intenso sobre tabla de madera'
  },
  {
    name: 'Avena y miel',
    description: 'Sabor suave, notas tostadas y dulzor natural.',
    price: '$5.400 / docena',
    image: '/images/product-oat-honey.webp',
    alt: 'Galletitas de avena y miel en plato de ceramica'
  },
  {
    name: 'Limon',
    description: 'Aroma citrico, masa tierna y final fresco.',
    price: '$5.600 / docena',
    image: '/images/product-lemon.webp',
    alt: 'Galletitas de limon con ralladura por encima'
  },
  {
    name: 'Almendras tostadas',
    description: 'Textura crocante con almendra real y manteca.',
    price: '$6.100 / docena',
    image: '/images/product-almond.webp',
    alt: 'Galletitas de almendras tostadas junto a almendras enteras'
  }
];
---

<BaseLayout
  title="Galletitas artesanales en Buenos Aires | Pedidos por WhatsApp"
  description="Casa de galletitas artesanales en Buenos Aires. Sabores clasicos, tandas semanales y pedidos por WhatsApp."
>
  <main id="contenido">
    <Hero />
    <SectionIntro />

    <section class="section section--products" aria-labelledby="productos-title">
      <div class="container">
        <h2 id="productos-title">Sabores de esta semana</h2>
        <div class="products-grid">
          {
            products.map((product) => (
              <ProductCard
                name={product.name}
                description={product.description}
                price={product.price}
                image={product.image}
                alt={product.alt}
              />
            ))
          }
        </div>
      </div>
    </section>

    <HowToOrder />
    <Testimonials />
    <CTA />
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>Casa de Galletitas - Buenos Aires, Argentina</p>
      <a href="https://wa.me/54911XXXXXXXX?text=Hola%2C%20quiero%20pedir%20galletitas." target="_blank" rel="noreferrer">
        WhatsApp
      </a>
    </div>
  </footer>
</BaseLayout>
