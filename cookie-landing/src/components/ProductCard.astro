---
interface Props {
  name: string;
  description: string;
  price: string;
  image: string;
  alt: string;
}

const { name, description, price, image, alt } = Astro.props;

const whatsappBase = 'https://wa.me/54911XXXXXXXX';
const text = encodeURIComponent(`Hola, quiero pedir galletitas de ${name}.`);
const whatsappLink = `${whatsappBase}?text=${text}`;
---

<article class="product-card">
  <img src={image} alt={alt} width="640" height="480" loading="lazy" decoding="async" />

  <div class="product-card__content">
    <h3>{name}</h3>
    <p>{description}</p>
    <div class="product-card__footer">
      <span class="price">{price}</span>
      <a class="btn btn--secondary" href={whatsappLink} target="_blank" rel="noreferrer">Pedir</a>
    </div>
  </div>
</article>
